  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run check:portuguese && next build",
    "start": "next start",
    "lint": "next lint",
    "cap:sync": "cap sync android",
    "cap:open": "cap open android",
    "android:debug": "npm run cap:sync && cd android && gradlew.bat assembleDebug && cd .. && npm run apk:publish-latest",
