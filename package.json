    "android:admin-debug": "tsx scripts/build-admin-apk.ts",
    "apk:publish-latest": "tsx scripts/publish-latest-apk.ts",
    "test:expiration": "tsx scripts/verify-expiration-policy.ts",
    "jobs:service-profile-activity": "tsx scripts/apply-service-profile-activity-policy.ts",
    "check:portuguese": "tsx scripts/check-portuguese.ts"
  },
  "dependencies": {
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/push-notifications": "^8.1.1",
    "@capawesome/capacitor-badge": "^8.0.2",
    "@supabase/supabase-js": "^2.106.2",
    "bcryptjs": "^2.4.3",
    "firebase": "^12.14.0",
    "firebase-admin": "^13.10.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.468.0",
    "next": "^14.2.18",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
