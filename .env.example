# Validação de CPF - opcional. O algoritmo oficial local continua obrigatório.
# HYDRACPF_API_URL aceita URL base ou URL com {cpf}. Ex.: https://api.exemplo.com/cpf/{cpf}
HYDRACPF_API_URL=""
HYDRACPF_API_TOKEN=""
HYDRACPF_API_HEADER="Authorization"
# ValidaSeguro documenta GET /api/validar/cpf/{cpf} com header X-API-Key.
